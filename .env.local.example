# ============================================================
#  PranaGreen Landing — biến môi trường
#  Copy file này thành ".env.local" rồi điền giá trị thật.
# ============================================================

# --- Supabase (lưu đơn hàng) -------------------------------
# Lấy tại: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role key — CHỈ dùng ở server, TUYỆT ĐỐI không lộ ra client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- SePay (nhận chuyển khoản tự động) ---------------------
# Số tài khoản & mã ngân hàng dùng để tạo mã QR VietQR
# Danh sách mã bank: MB, VCB, ACB, TCB, BIDV, VPB, TPB, VIB, MSB...
NEXT_PUBLIC_SEPAY_ACCOUNT=0123456789
NEXT_PUBLIC_SEPAY_BANK=MB
# API key bảo mật webhook — bạn tự đặt trong SePay > Webhooks (Authorization: Apikey ...)
SEPAY_WEBHOOK_API_KEY=doi-thanh-chuoi-bi-mat-cua-ban

# --- Link nhóm Zalo trả cho khách sau khi thanh toán -------
NEXT_PUBLIC_ZALO_GROUP_LINK=https://zalo.me/g/xxxxxx

# --- Trang admin (xem danh sách đơn) -----------------------
ADMIN_PASSWORD=doi-mat-khau-nay

# --- Email xác nhận (tuỳ chọn — để trống nếu chưa dùng) ----
# Đăng ký miễn phí tại resend.com để lấy API key
RESEND_API_KEY=
EMAIL_FROM=PranaGreen <no-reply@yourdomain.com>

# --- URL public của site (dùng cho email) ------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Nhắc thanh toán khi khách chưa chuyển khoản -----------
# Sau bao nhiêu phút "pending" thì gửi 1 email nhắc (mặc định 30)
PENDING_REMINDER_MINUTES=30
# Chuỗi bí mật để bảo vệ endpoint cron — tự đặt, dùng khi cấu hình
# lịch gọi định kỳ tới /api/cron/remind-pending (xem README)
CRON_SECRET=doi-thanh-chuoi-bi-mat-khac-cua-ban

# --- Meta Pixel (đo lường quảng cáo Facebook) --------------
# Tạo tại business.facebook.com/events_manager > Connect Data Sources > Web
# Để trống nếu chưa chạy ads — landing vẫn chạy bình thường.
NEXT_PUBLIC_META_PIXEL_ID=

# --- Microsoft Clarity (heatmap, ghi lại phiên khách xem web) ---
# Tạo project miễn phí tại clarity.microsoft.com > Add new project
NEXT_PUBLIC_CLARITY_ID=
